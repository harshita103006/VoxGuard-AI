# VoxGuard AI — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# (The .env file is gitignored by default)

# Backend URL for the FastAPI server
# In dev: leave blank — Vite proxies /api/* → http://localhost:8000/*  (configured in vite.config.js)
# In prod: set this to your deployed backend URL, e.g.:
#   VITE_API_BASE_URL=https://api.voxguard.example.com
VITE_API_BASE_URL=https://voxguard-ai-1zz7.onrender.com
